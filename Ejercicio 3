# Importamos librerías
import numpy as np
import matplotlib.pyplot as plt
from scipy.integrate import solve_ivp

#Parámetros
beta = 0.00003
gamma = 0.00003

# Definimos la ecuación diferencial
def modelo(t, I):
    return beta * I * (10000 - I) - gamma * I

# Se define el ntervalo de tiempo
t_span = (0, 100)  # de 0 a 100 días
t_eval = np.linspace(0, 100, 200)

#Condición inicial
I0 = [50]

# RSe resuelve la EDO con metodo solve de scipy 
sol = solve_ivp(modelo, t_span, I0, t_eval=t_eval)

# Imprimimos los resultados
print("Tiempo (días)    Infectados")
print("-" * 30)
for t, i in zip(sol.t, sol.y[0]):
    print(f"{t:10.2f}    {i:10.2f}")

# Graficar
plt.plot(sol.t, sol.y[0])
plt.xlabel("Tiempo")
plt.ylabel("Infectados")
plt.title("Evolución de la epidemia (solve_ivp)")
plt.grid()
plt.show()
